{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIUsage",
  "version": "0.1.0",
  "identifier": "com.aiusage.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "AIUsage",
        "width": 420,
        "height": 720,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
